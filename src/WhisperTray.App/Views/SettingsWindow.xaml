<Window x:Class="WhisperTray.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperTray — Settings"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="#F4F4F4">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Dictation settings"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hotkey" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="HotkeyBox"
                             Grid.Row="0" Grid.Column="1"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                             GotFocus="HotkeyBox_GotFocus"
                             ToolTip="Click inside, then press the desired combination."
                             Margin="0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Start with Windows" VerticalAlignment="Center" Margin="0,6"/>
                    <CheckBox x:Name="AutostartCheck" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Provider" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox x:Name="ProviderCombo"
                              Grid.Row="2" Grid.Column="1"
                              SelectionChanged="ProviderCombo_SelectionChanged"
                              Margin="0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Base URL" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="BaseUrlBox" Grid.Row="3" Grid.Column="1" Margin="0,6"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox x:Name="ModelCombo" Grid.Row="4" Grid.Column="1" IsEditable="True" Margin="0,6"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="API key" VerticalAlignment="Center" Margin="0,6"/>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Row="5" Grid.Column="1" Margin="0,6"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Language (optional)" VerticalAlignment="Center" Margin="0,6"/>
                    <TextBox x:Name="LanguageBox" Grid.Row="6" Grid.Column="1"
                             ToolTip="e.g. en, ru — leave empty for auto-detect."
                             Margin="0,6"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Prompt hint" VerticalAlignment="Top" Margin="0,10,0,0"/>
                    <TextBox x:Name="PromptBox" Grid.Row="7" Grid.Column="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,6"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Audio format" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox x:Name="AudioFormatCombo" Grid.Row="8" Grid.Column="1" Margin="0,6"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Injection mode" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox x:Name="InjectionModeCombo" Grid.Row="9" Grid.Column="1" Margin="0,6"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                x:Name="ErrorPanel"
                Background="#FDECEA"
                BorderBrush="#E57373"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,12,0,0"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#B71C1C"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Save" Width="90" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
